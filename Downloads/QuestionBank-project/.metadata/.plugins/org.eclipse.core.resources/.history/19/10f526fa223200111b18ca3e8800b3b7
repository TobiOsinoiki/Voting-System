<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OTP Verification | Online Question Bank System</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-page="otp">
  <main class="page-center">
    <div class="auth-shell">
      <div class="auth-header">
        <a href="/home.html" class="brand">
          <img class="brand-mark" src="/images/quiz-logo.jpg" alt="Quiz logo">
          <span class="brand-text">
            <span>Online Question Bank</span>
            <small>Back to homepage</small>
          </span>
        </a>
      </div>

      <section class="auth-card">
        <span class="eyebrow">OTP verification</span>
        <h1 class="page-title">Verify OTP</h1>
        <p class="page-subtitle">Enter the OTP sent to <strong id="otpEmail">your email</strong> to continue.</p>

        <form id="otpForm" class="form" novalidate>
          <div class="field">
            <label for="otp">OTP Code</label>
            <input id="otp" name="otp" type="text" placeholder="Enter the OTP code">
            <span class="field-error" data-error-for="otp"></span>
          </div>

          <div class="form-message" aria-live="polite"></div>
          <button type="submit" class="btn btn-primary">Verify OTP</button>
        </form>

        <p class="footer-note">Back to <a class="muted-link" href="/login.html">Login</a></p>
      </section>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
