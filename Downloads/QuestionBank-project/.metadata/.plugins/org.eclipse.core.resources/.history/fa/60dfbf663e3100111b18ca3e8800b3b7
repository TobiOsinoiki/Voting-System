<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Result | Online Question Bank System</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-page="result">
  <main class="page-center">
    <div class="auth-shell">
      <div class="auth-header">
        <a href="/home.html" class="brand">
          <img class="brand-mark" src="/images/quiz-logo.jpg" alt="Quiz logo">
          <span class="brand-text">
            <span>Online Question Bank</span>
            <small>Back to homepage</small>
          </span>
        </a>
      </div>

      <section class="result-card">
        <div class="header-row">
          <div>
            <span class="eyebrow">Quiz completed</span>
            <h1 class="page-title">Your Result</h1>
          </div>
          <div id="resultStatus" class="status-chip">Result</div>
        </div>

        <div id="resultScore" class="result-score">0/0</div>
        <p id="resultMessage" class="result-message">Your score details will appear here.</p>

        <div id="resultSummary" class="summary-grid"></div>

        <div class="inline-actions">
          <a class="btn btn-primary" href="/dashboard.html">Back to Dashboard</a>
        </div>
      </section>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
