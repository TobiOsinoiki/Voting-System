<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Online Question Bank System</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-page="login">
  <main class="page-center">
    <div class="auth-shell">
      <div class="auth-header">
        <a href="/home.html" class="brand">
          <img class="brand-mark" src="/images/quiz-logo.jpg" alt="Quiz logo">
          <span class="brand-text">
            <span>Online Question Bank</span>
            <small>Back to homepage</small>
          </span>
        </a>
      </div>

      <section class="auth-card">
        <span class="eyebrow">Welcome back</span>
        <h1 class="page-title">Login</h1>
        <p class="page-subtitle">Enter your email and password to continue to your dashboard.</p>

        <form id="loginForm" class="form" novalidate>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="Enter your email address">
            <span class="field-error" data-error-for="email"></span>
          </div>

          <div class="field">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" placeholder="Enter your password">
            <span class="field-error" data-error-for="password"></span>
          </div>

          <div class="helper-row">
            <span>Need help accessing your account?</span>
            <a class="muted-link" href="/forgot-password.html">Forgot Password</a>
          </div>

          <div class="form-message" aria-live="polite"></div>
          <button type="submit" class="btn btn-primary">Login</button>
        </form>

        <p class="footer-note">New here? <a class="muted-link" href="/register.html">Create an account</a></p>
      </section>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
