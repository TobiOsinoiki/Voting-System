<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Online Question Bank System</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-page="forgot-password">
  <main class="page-center">
    <div class="auth-shell">
      <div class="auth-header">
        <a href="/home.html" class="brand">
          <img class="brand-mark" src="/images/quiz-logo.jpg" alt="Quiz logo">
          <span class="brand-text">
            <span>Online Question Bank</span>
            <small>Back to homepage</small>
          </span>
        </a>
      </div>

      <section class="auth-card">
        <span class="eyebrow">Password recovery</span>
        <h1 class="page-title">Forgot Password</h1>
        <p class="page-subtitle">Enter your email address and we will send an OTP for verification.</p>

        <form id="forgotPasswordForm" class="form" novalidate>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="Enter your email address">
            <span class="field-error" data-error-for="email"></span>
          </div>

          <div class="form-message" aria-live="polite"></div>
          <button type="submit" class="btn btn-primary">Send OTP</button>
        </form>

        <p class="footer-note">Remembered your password? <a class="muted-link" href="/login.html">Go back to login</a></p>
      </section>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
