@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap");

:root {
  --bg: #f6f7fb;
  --bg-soft: #eef2ff;
  --surface: #ffffff;
  --surface-soft: #fbfbfe;
  --text: #111827;
  --muted: #6b7280;
  --primary: #4f46e5;
  --primary-dark: #4338ca;
  --primary-soft: rgba(79, 70, 229, 0.1);
  --border: rgba(17, 24, 39, 0.08);
  --danger: #dc2626;
  --success: #15803d;
  --warning: #b45309;
  --shadow-sm: 0 10px 24px rgba(15, 23, 42, 0.05);
  --shadow-md: 0 18px 44px rgba(15, 23, 42, 0.08);
  --radius-lg: 12px;
  --radius-md: 10px;
  --radius-sm: 8px;
  --container: 1120px;
  --transition: 0.35s ease-in-out;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: "Inter", sans-serif;
  color: var(--text);
  background:
    radial-gradient(circle at top left, rgba(79, 70, 229, 0.05), transparent 28%),
    linear-gradient(180deg, #fbfbfd 0%, var(--bg) 100%);
  animation: pageFade 0.45s ease-in-out;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font: inherit;
}

.page-shell {
  width: min(100% - 32px, var(--container));
  margin: 0 auto;
}

.page-center {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 32px 16px;
}

.hero-layout,
.content-layout {
  padding: 28px 0 56px;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 8px 0 24px;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  transition: transform var(--transition);
}

.brand:hover {
  transform: translateY(-1px);
}

.brand-mark {
  width: 72px;
  height: 72px;
  display: block;
  object-fit: contain;
}

.brand-text {
  display: grid;
  gap: 2px;
}

.brand-text span {
  font-size: 1rem;
  font-weight: 700;
}

.brand-text small {
  color: var(--muted);
  font-size: 0.74rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.nav-actions,
.hero-actions,
.inline-actions,
.helper-row,
.stats-grid,
.feature-grid,
.summary-grid {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.hero {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 24px;
  align-items: stretch;
}

.home-lower-grid,
.dashboard-grid {
  display: grid;
  gap: 20px;
  margin-top: 20px;
}

.home-lower-grid {
  grid-template-columns: 1.15fr 0.85fr;
}

.dashboard-grid {
  grid-template-columns: 1.2fr 0.8fr;
  align-items: start;
}

.card,
.panel,
.hero-card,
.question-card,
.showcase-card,
.timeline-card,
.auth-card,
.result-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  animation: slideUp 0.5s ease-in-out both;
}

.card,
.panel,
.hero-card,
.question-card,
.showcase-card,
.timeline-card,
.auth-card,
.result-card {
  padding: 28px;
}

.hero-card.primary-hero {
  background: linear-gradient(180deg, #ffffff 0%, #f7f7ff 100%);
}

.hero-card h1,
.page-title {
  margin: 14px 0 12px;
  line-height: 1.05;
  letter-spacing: -0.04em;
}

.hero-card h1 {
  font-size: clamp(2.6rem, 6vw, 4.4rem);
}

.page-title {
  font-size: clamp(1.95rem, 5vw, 3rem);
}

.section-title {
  margin: 12px 0 10px;
  font-size: clamp(1.45rem, 3vw, 2rem);
  letter-spacing: -0.03em;
}

.eyebrow,
.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
}

.eyebrow {
  background: var(--primary-soft);
  color: var(--primary);
}

.status-chip {
  background: #f3f4f6;
  color: var(--text);
}

.status-chip.success {
  background: rgba(21, 128, 61, 0.1);
  color: var(--success);
}

.status-chip.warning {
  background: rgba(180, 83, 9, 0.12);
  color: var(--warning);
}

.hero-copy,
.page-subtitle,
.intro-copy,
.feature-card p,
.summary-item span,
.stat-line span,
.timeline-entry p,
.footer-note,
.result-message,
.welcome-note,
.loading-state,
.empty-state {
  color: var(--muted);
  line-height: 1.7;
}

.hero-actions,
.inline-actions {
  margin-top: 24px;
}

.metric-strip,
.stat-list,
.timeline-list,
.question-list,
.option-list,
.form {
  display: grid;
  gap: 16px;
}

.metric-strip {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 28px;
}

.metric-card,
.feature-card,
.summary-item,
.stat-line {
  padding: 18px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: var(--surface-soft);
}

.metric-card strong,
.summary-item strong,
.stat-line strong {
  display: block;
  margin-bottom: 6px;
  font-size: 1rem;
}

.feature-grid,
.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.timeline-entry {
  display: grid;
  grid-template-columns: 42px 1fr;
  gap: 14px;
  align-items: start;
}

.timeline-step {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 10px;
  background: var(--primary-soft);
  color: var(--primary);
  font-weight: 800;
}

.showcase-card {
  background: linear-gradient(180deg, #ffffff 0%, #fafaff 100%);
}

.auth-shell {
  width: min(100%, 460px);
  position: relative;
}

.auth-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 18px;
  animation: slideUp 0.45s ease-in-out both;
}

.form {
  margin-top: 18px;
}

.field {
  display: grid;
  gap: 8px;
}

.field label {
  font-size: 0.94rem;
  font-weight: 600;
}

.field input {
  width: 100%;
  min-height: 52px;
  padding: 0 16px;
  border: 1px solid rgba(17, 24, 39, 0.12);
  border-radius: 10px;
  background: #fff;
  color: var(--text);
  transition:
    border-color var(--transition),
    box-shadow var(--transition),
    transform var(--transition);
}

.field input:focus {
  outline: none;
  border-color: rgba(79, 70, 229, 0.45);
  box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
  transform: translateY(-1px);
}

.field input[aria-invalid="true"] {
  border-color: rgba(220, 38, 38, 0.5);
  box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.08);
}

.field-error,
.form-message {
  min-height: 1.1em;
  font-size: 0.9rem;
}

.field-error,
.form-message.error {
  color: var(--danger);
}

.form-message.success {
  color: var(--success);
}

.helper-row {
  justify-content: space-between;
  align-items: center;
}

.btn {
  min-height: 50px;
  padding: 0 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  border: 1px solid transparent;
  font-weight: 600;
  cursor: pointer;
  transition:
    transform 0.3s ease-in-out,
    box-shadow 0.3s ease-in-out,
    background-color 0.3s ease-in-out,
    border-color 0.3s ease-in-out,
    color 0.3s ease-in-out;
}

.btn:hover {
  transform: scale(1.02);
  box-shadow: var(--shadow-md);
}

.btn:disabled {
  opacity: 0.7;
  cursor: wait;
  transform: none;
  box-shadow: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-primary:hover {
  background: var(--primary-dark);
}

.btn-secondary,
.btn-outline {
  background: #fff;
  color: var(--text);
  border-color: rgba(17, 24, 39, 0.1);
}

.btn-secondary:hover,
.btn-outline:hover {
  border-color: rgba(79, 70, 229, 0.25);
  color: var(--primary-dark);
}

.btn-danger {
  background: #fff;
  color: var(--danger);
  border-color: rgba(220, 38, 38, 0.14);
}

.muted-link {
  color: var(--primary);
  transition: color 0.3s ease-in-out;
}

.muted-link:hover {
  color: var(--primary-dark);
}

.welcome-banner {
  padding: 24px;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #ffffff 0%, #f8f8ff 100%);
}

.welcome-note {
  margin-top: 10px;
}

.quiz-card {
  width: 100%;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.question-card h3 {
  margin: 0 0 16px;
  font-size: 1.05rem;
}

.option-item {
  position: relative;
}

.option-item input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.option-label {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-radius: 10px;
  border: 1px solid rgba(17, 24, 39, 0.08);
  background: #fff;
  cursor: pointer;
  transition: all var(--transition);
}

.option-label::before {
  content: "";
  width: 18px;
  height: 18px;
  flex: none;
  border-radius: 999px;
  border: 2px solid rgba(107, 114, 128, 0.45);
  transition: all var(--transition);
}

.option-item input:checked + .option-label {
  border-color: rgba(79, 70, 229, 0.28);
  background: rgba(79, 70, 229, 0.05);
  box-shadow: 0 10px 22px rgba(79, 70, 229, 0.08);
}

.option-item input:checked + .option-label::before {
  border-color: var(--primary);
  background: radial-gradient(circle, var(--primary) 42%, #fff 43%);
}

.loading-state,
.empty-state {
  padding: 24px;
  text-align: center;
  border: 1px dashed rgba(17, 24, 39, 0.12);
  border-radius: 10px;
}

.result-card {
  text-align: center;
}

.result-score {
  margin: 14px 0 10px;
  font-size: clamp(3rem, 8vw, 4.6rem);
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.05em;
}

.footer-note {
  margin-top: 18px;
  text-align: center;
}

@keyframes pageFade {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 920px) {
  .hero,
  .home-lower-grid,
  .dashboard-grid,
  .feature-grid,
  .summary-grid,
  .metric-strip {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .page-shell {
    width: min(100% - 20px, var(--container));
  }

  .topbar,
  .nav-actions,
  .hero-actions,
  .inline-actions,
  .helper-row,
  .header-row {
    flex-direction: column;
    align-items: stretch;
  }

  .btn {
    width: 100%;
  }

  .auth-header {
    justify-content: flex-start;
  }

  .card,
  .panel,
  .hero-card,
  .question-card,
  .showcase-card,
  .timeline-card,
  .auth-card,
  .result-card {
    padding: 22px;
  }
}
